page {
  background-color: #f8f8f8;
  font-size: 28rpx;
  color: #333333;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

.news-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.news-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.news-summary {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.news-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999999;
}

.btn-primary {
  background-color: #1AAD19;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
  margin: 20rpx 0;
}

.btn-danger {
  background-color: #E64340;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
  margin: 20rpx 0;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #eeeeee;
  margin-bottom: 20rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
}