.lecture-list {
  padding: 20rpx;
}

.lecture-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.lecture-header {
  position: relative;
  height: 300rpx;
}

.lecture-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1AAD19, #007AFF);
}

.placeholder-text {
  color: #ffffff;
  font-size: 96rpx;
  font-weight: bold;
}

.lecture-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #ffffff;
  border-radius: 30rpx;
}

.lecture-badge.free {
  background-color: #1AAD19;
}

.lecture-badge.paid {
  background-color: #E64340;
}

.lecture-content {
  padding: 24rpx;
}

.lecture-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.lecture-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  font-size: 26rpx;
}

.label {
  color: #999999;
  width: 140rpx;
}

.value {
  color: #666666;
  flex: 1;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.refresh-bar {
  padding: 10rpx 30rpx;
  background-color: #f8f8f8;
  border-bottom: 1rpx solid #eeeeee;
}

.refresh-time {
  font-size: 22rpx;
  color: #bbbbbb;
}
