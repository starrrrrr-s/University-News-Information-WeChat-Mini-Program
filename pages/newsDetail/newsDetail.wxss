.news-detail {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background-color: #f8f8f8;
}

.news-header {
  padding: 30rpx;
  background-color: #ffffff;
}

.category-tag {
  display: inline-block;
  color: #ffffff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 20rpx;
}

.news-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.news-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.author {
  color: #1AAD19;
}

.separator {
  color: #dddddd;
}

.news-cover {
  margin: 0 0 20rpx;
}

.news-placeholder {
  width: 100%;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  color: #ffffff;
  font-size: 120rpx;
  font-weight: bold;
  opacity: 0.6;
}

.news-content {
  padding: 30rpx;
  background-color: #ffffff;
  font-size: 30rpx;
  color: #333333;
  line-height: 1.9;
  text-align: justify;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 30rpx;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 50rpx;
  background-color: #f5f5f5;
  border: none;
  border-radius: 60rpx;
  font-size: 28rpx;
  color: #666666;
  flex: 1;
}

.action-btn.collected {
  background-color: #FFF5E6;
  color: #FF9500;
}

.action-btn.share-btn {
  background-color: #f0faf0;
  color: #1AAD19;
}

.action-icon {
  font-size: 34rpx;
  margin-right: 10rpx;
}

.action-text {
  font-size: 28rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}
