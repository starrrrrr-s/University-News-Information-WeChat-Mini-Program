.news-detail {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background-color: #f8f8f8;
}

.news-header {
  padding: 30rpx;
  background-color: #ffffff;
}

.category-tag {
  display: inline-block;
  color: #ffffff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 20rpx;
}

.news-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.news-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.author {
  color: #1AAD19;
}

.separator {
  color: #dddddd;
}

.news-images {
  margin: 0 0 20rpx;
  background-color: #000000;
}

.images-swiper {
  width: 100%;
  height: 400rpx;
}

.news-image {
  width: 100%;
  height: 100%;
}

.news-content {
  padding: 30rpx;
  background-color: #ffffff;
  font-size: 30rpx;
  color: #333333;
  line-height: 1.9;
  text-align: justify;
}

/* ─── 评论区 ─────────────────────────────────────────────── */

.comment-section {
  margin-top: 20rpx;
  background-color: #ffffff;
  padding: 30rpx;
  padding-bottom: 40rpx;
}

.comment-header {
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 20rpx;
}

.comment-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.comment-list {
  /* 评论列表容器 */
}

.comment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}

.comment-item:last-child {
  border-bottom: none;
}

.top-badge {
  display: inline-block;
  background-color: #E64340;
  color: #ffffff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  margin-bottom: 10rpx;
}

.comment-main {
  display: flex;
  align-items: flex-start;
}

.comment-avatar {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
}

.avatar-placeholder-small {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background-color: #1AAD19;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-small text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
}

.comment-body {
  flex: 1;
}

.comment-user-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.reply-to {
  margin-bottom: 6rpx;
}

.reply-label {
  font-size: 22rpx;
  color: #1AAD19;
  background-color: #f0faf0;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.comment-content {
  font-size: 28rpx;
  color: #444444;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.comment-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.comment-time {
  font-size: 22rpx;
  color: #bbbbbb;
}

.reply-btn {
  font-size: 24rpx;
  color: #1AAD19;
  padding: 4rpx 16rpx;
}

.comment-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #bbbbbb;
  font-size: 26rpx;
}

.load-more {
  text-align: center;
  padding: 24rpx 0;
  color: #1AAD19;
  font-size: 26rpx;
}

/* ─── 底部操作栏 ─────────────────────────────────────────── */

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 30rpx;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 30rpx;
  background-color: #f5f5f5;
  border: none;
  border-radius: 60rpx;
  font-size: 26rpx;
  color: #666666;
  flex: 1;
}

.action-btn.collected {
  background-color: #FFF5E6;
  color: #FF9500;
}

.action-btn.comment-btn {
  background-color: #f0f8ff;
  color: #007AFF;
}

.action-btn.share-btn {
  background-color: #f0faf0;
  color: #1AAD19;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 26rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* ─── 评论输入框 ─────────────────────────────────────────── */

.comment-input-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  z-index: 99;
}

.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.reply-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0 12rpx;
  font-size: 24rpx;
  color: #666666;
}

.cancel-reply {
  color: #E64340;
  font-size: 24rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  min-height: 72rpx;
}

.send-btn {
  background-color: #1AAD19;
  color: #ffffff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: none;
  flex-shrink: 0;
}

.send-btn[disabled] {
  background-color: #cccccc;
  color: #ffffff;
}

/* 查看原文样式 */
.source-link-section {
  margin-top: 30rpx;
  padding: 30rpx;
  background-color: #ffffff;
}

.source-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e0e0e0, transparent);
  margin-bottom: 30rpx;
}

.source-link {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.source-label {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.source-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #f5f9ff, #f0f7ff);
  border: 2rpx solid #e0f0ff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  transition: all 0.3s ease;
}

.source-btn:active {
  background: linear-gradient(135deg, #e0f0ff, #d0e8ff);
  transform: scale(0.98);
}

.source-url {
  flex: 1;
  font-size: 24rpx;
  color: #007AFF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.source-arrow {
  font-size: 32rpx;
  color: #007AFF;
  font-weight: bold;
}
