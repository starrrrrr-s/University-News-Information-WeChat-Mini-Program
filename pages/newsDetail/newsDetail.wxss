.news-detail {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background-color: #f8f8f8;
}

.news-header {
  padding: 30rpx;
  background-color: #ffffff;
}

.category-tag {
  display: inline-block;
  color: #ffffff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 20rpx;
}

.news-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.news-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.author {
  color: #1AAD19;
}

.separator {
  color: #dddddd;
}

.news-images {
  margin: 0 0 20rpx;
  background-color: #000000;
}

.images-swiper {
  width: 100%;
  height: 400rpx;
}

.news-image {
  width: 100%;
  height: 100%;
}

.news-content {
  padding: 30rpx;
  background-color: #ffffff;
  font-size: 30rpx;
  color: #333333;
  line-height: 1.9;
  text-align: justify;
}

/* ─── 评论区 ─────────────────────────────────────────────── */

.comment-section {
  margin-top: 20rpx;
  background-color: #ffffff;
  padding: 30rpx;
  padding-bottom: 40rpx;
}

.comment-header {
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 20rpx;
}

.comment-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.comment-list {
  /* 评论列表容器 */
}

.comment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}

.comment-item:last-child {
  border-bottom: none;
}

.top-badge {
  display: inline-block;
  background-color: #E64340;
  color: #ffffff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  margin-bottom: 10rpx;
}

.comment-main {
  display: flex;
  align-items: flex-start;
}

.comment-avatar {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
}

.avatar-placeholder-small {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background-color: #1AAD19;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-small text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
}

.comment-body {
  flex: 1;
}

.comment-user-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.reply-to {
  margin-bottom: 6rpx;
}

.reply-label {
  font-size: 22rpx;
  color: #1AAD19;
  background-color: #f0faf0;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.comment-content {
  font-size: 28rpx;
  color: #444444;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.comment-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.comment-time {
  font-size: 22rpx;
  color: #bbbbbb;
}

.reply-btn {
  font-size: 24rpx;
  color: #1AAD19;
  padding: 4rpx 16rpx;
}

.comment-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #bbbbbb;
  font-size: 26rpx;
}

.load-more {
  text-align: center;
  padding: 24rpx 0;
  color: #1AAD19;
  font-size: 26rpx;
}

/* ─── 底部操作栏 ─────────────────────────────────────────── */

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 30rpx;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 30rpx;
  background-color: #f5f5f5;
  border: none;
  border-radius: 60rpx;
  font-size: 26rpx;
  color: #666666;
  flex: 1;
}

.action-btn.collected {
  background-color: #FFF5E6;
  color: #FF9500;
}

.action-btn.comment-btn {
  background-color: #f0f8ff;
  color: #007AFF;
}

.action-btn.share-btn {
  background-color: #f0faf0;
  color: #1AAD19;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 26rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* ─── 评论输入框 ─────────────────────────────────────────── */

.comment-input-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  z-index: 99;
}

.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.reply-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0 12rpx;
  font-size: 24rpx;
  color: #666666;
}

.cancel-reply {
  color: #E64340;
  font-size: 24rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  min-height: 72rpx;
}

.send-btn {
  background-color: #1AAD19;
  color: #ffffff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: none;
  flex-shrink: 0;
}

.send-btn[disabled] {
  background-color: #cccccc;
  color: #ffffff;
}

/* 查看原文样式 */
.source-link-section {
  margin-top: 30rpx;
  padding: 30rpx;
  background-color: #ffffff;
}

.source-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e0e0e0, transparent);
  margin-bottom: 30rpx;
}

.source-link {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.source-label {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.source-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #f5f9ff, #f0f7ff);
  border: 2rpx solid #e0f0ff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  transition: all 0.3s ease;
}

.source-btn:active {
  background: linear-gradient(135deg, #e0f0ff, #d0e8ff);
  transform: scale(0.98);
}

.source-url {
  flex: 1;
  font-size: 24rpx;
  color: #007AFF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.source-arrow {
  font-size: 32rpx;
  color: #007AFF;
  font-weight: bold;
}

/* ─── AI 智能助手卡片 ────────────────────────────────────── */

.ai-section {
  margin-top: 30rpx;
  padding: 30rpx;
  background-color: #ffffff;
}

.ai-card {
  background: linear-gradient(180deg, #f8f9ff 0%, #ffffff 100%);
  border: 2rpx solid #e8eefc;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.08);
}

/* 卡片头部 */
.ai-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f4ff;
}

.ai-title-wrapper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.ai-icon {
  font-size: 36rpx;
}

.ai-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3748;
  letter-spacing: 0.5rpx;
}

.ai-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 30rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  background: #ffffff;
  border-radius: 50%;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.status-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 加载状态 */
.ai-loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e7ff;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.ai-loading-text {
  font-size: 26rpx;
  color: #718096;
}

/* 错误状态 */
.ai-error-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 50rpx 0;
  gap: 12rpx;
}

.ai-error-icon {
  font-size: 48rpx;
}

.ai-error-text {
  font-size: 26rpx;
  color: #e53e3e;
}

/* 内容区域 */
.ai-content-wrapper {
  animation: fadeInUp 0.4s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 摘要部分 */
.ai-summary-box {
  background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
  border-left: 6rpx solid #f59e0b;
}

.summary-label {
  font-size: 24rpx;
  color: #92400e;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
}

.summary-text {
  font-size: 28rpx;
  color: #78350f;
  line-height: 1.8;
  display: block;
}

/* 要点列表 */
.key-points-section {
  margin-bottom: 28rpx;
}

.key-points-label {
  font-size: 24rpx;
  color: #4a5568;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.key-points-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.key-point-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  background-color: #f7fafc;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #edf2f7;
  transition: all 0.2s ease;
}

.key-point-item:active {
  background-color: #edf2f7;
  transform: scale(0.98);
}

.point-badge {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.point-text {
  flex: 1;
  font-size: 27rpx;
  color: #2d3748;
  line-height: 1.75;
  font-weight: 400;
}

/* 语音操作按钮 */
.ai-actions {
  margin-top: 20rpx;
}

.action-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
  margin-bottom: 24rpx;
}

.voice-buttons {
  display: flex;
  gap: 16rpx;
}

.voice-button {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 16rpx;
  background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  gap: 6rpx;
  transition: all 0.3s ease;
}

.voice-button.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: #667eea;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.voice-button:active {
  transform: scale(0.96);
}

.voice-icon {
  font-size: 32rpx;
}

.voice-button.active .voice-icon {
  animation: bounce 0.5s ease infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

.voice-label {
  font-size: 23rpx;
  color: #4a5568;
  font-weight: 500;
}

.voice-button.active .voice-label {
  color: #ffffff;
}

/* 提示获取区域 */
.ai-prompt-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-radius: 20rpx;
  border: 2rpx dashed #7dd3fc;
  gap: 12rpx;
  transition: all 0.3s ease;
}

.ai-prompt-wrapper:active {
  background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
  transform: scale(0.98);
}

.prompt-icon {
  font-size: 56rpx;
  animation: float 2s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.prompt-text {
  font-size: 29rpx;
  color: #0c4a6e;
  font-weight: 600;
}

.prompt-hint {
  font-size: 23rpx;
  color: #0369a1;
  opacity: 0.8;
}

/* 音色选择按钮 */
.voice-selector-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 20rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 0%);
  border: 2rpx solid #bae6fd;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.voice-selector-btn:active {
  transform: scale(0.98);
}

.selector-icon {
  font-size: 28rpx;
}

.selector-text {
  font-size: 25rpx;
  color: #0c4a6e;
  font-weight: 500;
}

.selector-arrow {
  font-size: 20rpx;
  color: #0284c7;
}

/* 音色选择器 */
.voice-selector {
  margin-top: 16rpx;
  background: #ffffff;
  border: 2rpx solid #e0f2fe;
  border-radius: 16rpx;
  overflow: hidden;
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.voice-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f9ff;
  transition: all 0.2s ease;
}

.voice-item:last-child {
  border-bottom: none;
}

.voice-item:active {
  background-color: #f0f9ff;
}

.voice-item.selected {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  border-left: 6rpx solid #3b82f6;
}

.voice-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e40af;
  margin-bottom: 6rpx;
}

.voice-desc {
  font-size: 23rpx;
  color: #64748b;
}
