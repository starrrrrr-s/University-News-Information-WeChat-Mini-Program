<view class="container">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="user-info" wx:if="{{isLoggedIn}}">
      <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" wx:if="{{userInfo.avatarUrl}}" />
      <view class="avatar-placeholder" wx:else>
        <text class="avatar-text">{{userInfo.nickName.charAt(0)}}</text>
      </view>
      <text class="nickname">{{userInfo.nickName}}</text>
      <view class="user-badge" wx:if="{{isAdmin}}">管理员</view>
    </view>
    <view class="login-prompt" wx:else bindtap="onLogin">
      <view class="avatar-placeholder">
        <text class="avatar-text">登</text>
      </view>
      <text class="login-text">点击登录</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onMyCollections">
      <text class="menu-icon">★</text>
      <text class="menu-text">我的收藏</text>
      <view class="menu-right">
        <text class="menu-badge" wx:if="{{isLoggedIn && collectionsCount > 0}}">{{collectionsCount}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 管理员功能 -->
  <view class="menu-section" wx:if="{{isAdmin}}">
    <view class="menu-section-title">管理功能</view>
    <view class="menu-item" bindtap="onAdminNews">
      <text class="menu-icon admin-icon">✎</text>
      <text class="menu-text">新闻管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAdminLecture">
      <text class="menu-icon admin-icon">✎</text>
      <text class="menu-text">讲座管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAdminUser">
      <text class="menu-icon admin-icon">☺</text>
      <text class="menu-text">用户管理</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>高校新闻资讯 v1.0.0</text>
  </view>
</view>
