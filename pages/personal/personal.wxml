<view class="container" style="--theme-color: {{themeColor}}">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="user-info" wx:if="{{isLoggedIn}}">
      <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" wx:if="{{userInfo.avatarUrl}}" />
      <view class="avatar-placeholder" wx:else>
        <text class="avatar-text">{{userInfo.nickName.charAt(0)}}</text>
      </view>
      <text class="nickname">{{userInfo.nickName}}</text>
      <view class="user-badge" wx:if="{{isAdmin}}">管理员</view>
    </view>
    <view class="login-prompt" wx:else>
      <view class="login-modal" wx:if="{{showLoginModal}}" catchtap="hideLoginModal">
        <view class="login-modal-content" catchtap="onModalContentTap">
          <view class="login-modal-header">
            <text class="login-modal-title">选择登录方式</text>
            <text class="login-modal-close" bindtap="hideLoginModal">×</text>
          </view>
          <view class="login-tabs">
            <view class="login-tab {{loginType === 'wechat' ? 'active' : ''}}" data-type="wechat" bindtap="setLoginType">
              <text>微信登录</text>
            </view>
            <view class="login-tab {{loginType === 'admin' ? 'active' : ''}}" data-type="admin" bindtap="setLoginType">
              <text>管理员登录</text>
            </view>
          </view>
          <view class="login-form">
            <!-- 微信登录 -->
            <view wx:if="{{loginType === 'wechat'}}" class="wechat-login">
              <button class="wechat-btn" bindtap="onWechatLogin">
                <text>微信快捷登录</text>
              </button>
            </view>
            <!-- 管理员登录 -->
            <view wx:if="{{loginType === 'admin'}}" class="admin-login">
              <view class="form-item">
                <input class="form-input" placeholder="用户名" value="{{adminUsername}}" bindinput="onAdminUsernameInput" />
              </view>
              <view class="form-item">
                <input class="form-input" type="password" placeholder="密码" value="{{adminPassword}}" bindinput="onAdminPasswordInput" />
              </view>
              <button class="admin-btn" bindtap="onAdminLogin">
                <text>管理员登录</text>
              </button>
            </view>
          </view>
        </view>
      </view>
      <view class="avatar-placeholder" bindtap="showLoginModal">
        <text class="avatar-text">登</text>
      </view>
      <text class="login-text">点击登录</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onMyCollections">
      <text class="menu-icon">★</text>
      <text class="menu-text">我的收藏</text>
      <view class="menu-right">
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="onFontSetting">
      <text class="menu-icon">🔤</text>
      <text class="menu-text">字体设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onFeedback">
      <text class="menu-icon">💬</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAbout">
      <text class="menu-icon">ℹ</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 管理员功能 -->
  <view class="menu-section" wx:if="{{isAdmin}}">
    <view class="menu-section-title">管理功能</view>
    <view class="menu-item" bindtap="onAdminNews">
      <text class="menu-icon admin-icon">✎</text>
      <text class="menu-text">新闻管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAdminLecture">
      <text class="menu-icon admin-icon">✎</text>
      <text class="menu-text">讲座管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAdminComment">
      <text class="menu-icon admin-icon">💬</text>
      <text class="menu-text">评论管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAdminFeedback">
      <text class="menu-icon admin-icon">📝</text>
      <text class="menu-text">反馈管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAdminUser">
      <text class="menu-icon admin-icon">☺</text>
      <text class="menu-text">用户管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAdminTheme">
      <text class="menu-icon admin-icon">🎨</text>
      <text class="menu-text">主题配置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>高校新闻资讯 v1.0.0</text>
  </view>
</view>
