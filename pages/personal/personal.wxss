.user-section {
  background: linear-gradient(135deg, var(--theme-color), #0d8a0d);
  padding: 60rpx 30rpx 50rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
}

.nickname {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.user-badge {
  background-color: #E64340;
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
}

.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
  background-color: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  color: #ffffff;
  font-size: 64rpx;
  font-weight: bold;
}

.login-text {
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}

.menu-section {
  margin: 20rpx 20rpx 0;
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.menu-section-title {
  font-size: 24rpx;
  color: #999999;
  padding: 20rpx 30rpx 10rpx;
  background-color: #fafafa;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  color: #1AAD19;
  margin-right: 20rpx;
  width: 50rpx;
  text-align: center;
}

.admin-icon {
  color: #FF9500;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.menu-badge {
  background-color: #E64340;
  color: #ffffff;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  text-align: center;
  line-height: 36rpx;
  padding: 0 8rpx;
}

.menu-arrow {
  color: #cccccc;
  font-size: 36rpx;
}

.logout-section {
  padding: 30rpx 20rpx;
}

.logout-btn {
  background-color: #ffffff;
  color: #E64340;
  font-size: 30rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.version-info {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #cccccc;
}

/* 登录弹窗 */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.login-modal-content {
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.login-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.login-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.login-modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.login-tabs {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.login-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.login-tab.active {
  color: #1AAD19;
}

.login-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background-color: #1AAD19;
}

.login-form {
  padding: 40rpx 30rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.wechat-btn {
  width: 100%;
  height: 88rpx;
  background-color: #1AAD19;
  color: #ffffff;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

.admin-btn {
  width: 100%;
  height: 88rpx;
  background-color: #FF9500;
  color: #ffffff;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}
