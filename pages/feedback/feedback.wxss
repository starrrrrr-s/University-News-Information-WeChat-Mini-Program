.feedback-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 提示区域 */
.tips-section {
  margin-bottom: 20rpx;
}

.tips-card {
  background: linear-gradient(135deg, #e8f5e9, #f1f8e9);
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tips-icon {
  font-size: 32rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #2e7d32;
  line-height: 1.6;
  flex: 1;
}

/* 表单区域 */
.form-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 10rpx 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #333333;
}

.required {
  color: #E64340;
  margin-right: 4rpx;
}

.optional {
  color: #999999;
  font-size: 24rpx;
  margin-left: 8rpx;
}

.char-count {
  margin-left: auto;
  font-size: 24rpx;
  color: #bbbbbb;
}

/* 选择器样式 */
.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.picker-value.placeholder {
  color: #bbbbbb;
}

.picker-arrow {
  color: #cccccc;
  font-size: 32rpx;
}

/* 输入框样式 */
.content-input {
  width: 100%;
  min-height: 200rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  box-sizing: border-box;
}

.contact-input {
  width: 100%;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.placeholder-text {
  color: #bbbbbb;
}

/* 提交按钮 */
.submit-section {
  padding: 0 20rpx;
}

.submit-btn {
  width: 100%;
  background-color: #1AAD19;
  color: #ffffff;
  font-size: 32rpx;
  padding: 28rpx;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(26, 173, 25, 0.3);
}

.submit-btn.disabled {
  background-color: #cccccc;
  box-shadow: none;
}

.submit-btn:active {
  opacity: 0.9;
}

/* 底部说明 */
.footer-note {
  text-align: center;
  padding: 40rpx 20rpx;
  font-size: 24rpx;
  color: #999999;
}
