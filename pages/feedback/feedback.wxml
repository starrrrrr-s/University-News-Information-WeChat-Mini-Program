<view class="feedback-container">
  <!-- 提示说明 -->
  <view class="tips-section">
    <view class="tips-card">
      <text class="tips-icon">💡</text>
      <text class="tips-text">您的意见对我们非常重要，我们会认真对待每一条反馈。</text>
    </view>
  </view>

  <!-- 反馈表单 -->
  <view class="form-section">
    <!-- 反馈类型 -->
    <view class="form-item">
      <view class="form-label">
        <text class="required">*</text>
        <text>反馈类型</text>
      </view>
      <picker mode="selector" range="{{feedbackTypes}}" bindchange="onTypeSelect">
        <view class="picker-value {{selectedType ? '' : 'placeholder'}}">
          <text>{{selectedType || '请选择反馈类型'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 反馈内容 -->
    <view class="form-item">
      <view class="form-label">
        <text class="required">*</text>
        <text>反馈内容</text>
        <text class="char-count">{{contentLength}}/{{maxLength}}</text>
      </view>
      <textarea 
        class="content-input"
        placeholder="请详细描述您的建议或遇到的问题，至少10个字..."
        maxlength="{{maxLength}}"
        value="{{content}}"
        bindinput="onContentInput"
        auto-height
        placeholder-class="placeholder-text"
      />
    </view>

    <!-- 联系方式（可选） -->
    <view class="form-item">
      <view class="form-label">
        <text>联系方式</text>
        <text class="optional">(选填)</text>
      </view>
      <input 
        class="contact-input"
        placeholder="手机号或邮箱，方便我们回复您"
        value="{{contact}}"
        bindinput="onContactInput"
        placeholder-class="placeholder-text"
      />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button 
      class="submit-btn {{submitting ? 'disabled' : ''}}" 
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交反馈'}}
    </button>
  </view>

  <!-- 底部说明 -->
  <view class="footer-note">
    <text>感谢您的反馈，我们会尽快处理！</text>
  </view>
</view>
