<view class="feedback-container">
  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === 'submit' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="submit"
    >
      <text>提交反馈</text>
    </view>
    <view
      class="tab-item {{activeTab === 'history' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="history"
    >
      <text>反馈记录</text>
      <view class="badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</view>
    </view>
  </view>

  <view wx:if="{{activeTab === 'submit'}}">
    <view class="tips-section">
      <view class="tips-card">
        <text class="tips-icon">💡</text>
        <text class="tips-text">您的意见对我们非常重要，我们会认真对待每一条反馈。</text>
      </view>
    </view>

    <view class="form-section">
      <view class="form-item">
        <view class="form-label">
          <text class="required">*</text>
          <text>反馈类型</text>
        </view>
        <picker mode="selector" range="{{feedbackTypes}}" bindchange="onTypeSelect">
          <view class="picker-value {{selectedType ? '' : 'placeholder'}}">
            <text>{{selectedType || '请选择反馈类型'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text class="required">*</text>
          <text>反馈内容</text>
          <text class="char-count">{{contentLength}}/{{maxLength}}</text>
        </view>
        <textarea
          class="content-input"
          placeholder="请详细描述您的建议或遇到的问题，至少10个字..."
          maxlength="{{maxLength}}"
          value="{{content}}"
          bindinput="onContentInput"
          auto-height
          placeholder-class="placeholder-text"
        />
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>联系方式</text>
          <text class="optional">(选填)</text>
        </view>
        <input
          class="contact-input"
          placeholder="手机号或邮箱，方便我们回复您"
          value="{{contact}}"
          bindinput="onContactInput"
          placeholder-class="placeholder-text"
        />
      </view>
    </view>

    <view class="submit-section">
      <button
        class="submit-btn {{submitting ? 'disabled' : ''}}"
        bindtap="onSubmit"
        disabled="{{submitting}}"
      >
        {{submitting ? '提交中...' : '提交反馈'}}
      </button>
    </view>

    <view class="footer-note">
      <text>感谢您的反馈，我们会尽快处理！</text>
    </view>
  </view>

  <view wx:if="{{activeTab === 'history'}}">
    <view class="history-section">
      <view wx:if="{{feedbackHistory.length === 0}}" class="empty-state">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无反馈记录</text>
      </view>

      <view wx:else class="history-list">
        <view
          class="history-item {{item.is_read ? '' : 'unread'}}"
          wx:for="{{feedbackHistory}}"
          wx:key="id"
          bindtap="viewFeedbackDetail"
          data-id="{{item.id}}"
        >
          <view class="history-header">
            <view class="type-badge {{getTypeClass(item.type)}}">{{item.type}}</view>
            <view class="status-tag {{getStatusClass(item.status)}}">{{item.statusText || getStatusText(item.status)}}</view>
          </view>
          <view class="history-content">
            <text>{{item.content}}</text>
          </view>
          <view class="history-footer">
            <text class="time">{{item.formattedTime}}</text>
            <view wx:if="{{item.reply && !item.is_read}}" class="new-reply">
              <text>有新回复</text>
            </view>
          </view>

          <view wx:if="{{item.reply}}" class="reply-section">
            <view class="reply-header">
              <text class="reply-label">管理员回复：</text>
            </view>
            <view class="reply-content">
              <text>{{item.reply}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showDetailModal}}" class="modal-overlay" bindtap="hideDetailModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">反馈详情</text>
        <view class="close-btn" bindtap="hideDetailModal">
          <text>×</text>
        </view>
      </view>
      <view class="modal-body" wx:if="{{currentDetail}}">
        <view class="detail-item">
          <text class="detail-label">反馈类型</text>
          <view class="type-badge {{getTypeClass(currentDetail.type)}}">{{currentDetail.type}}</view>
        </view>
        <view class="detail-item">
          <text class="detail-label">状态</text>
          <view class="status-tag {{getStatusClass(currentDetail.status)}}">{{currentDetail.statusText || getStatusText(currentDetail.status)}}</view>
        </view>
        <view class="detail-item">
          <text class="detail-label">反馈内容</text>
          <text class="detail-text">{{currentDetail.content}}</text>
        </view>
        <view class="detail-item" wx:if="{{currentDetail.contact}}">
          <text class="detail-label">联系方式</text>
          <text class="detail-text">{{currentDetail.contact}}</text>
        </view>
        <view class="detail-item" wx:if="{{currentDetail.reply}}">
          <text class="detail-label">管理员回复</text>
          <view class="reply-box">
            <text>{{currentDetail.reply}}</text>
          </view>
        </view>
        <view class="detail-item">
          <text class="detail-label">提交时间</text>
          <text class="detail-text">{{currentDetail.formattedTime}}</text>
        </view>
      </view>
    </view>
  </view>
</view>