/* 顶部 Hero 区域 */
.hero-section {
  background: linear-gradient(135deg, #1AAD19, #0d8a0d);
  padding: 60rpx 30rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: -20rpx -20rpx 20rpx;
}

.logo-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo-icon {
  font-size: 80rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.app-version {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 卡片 */
.card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.card-content {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.card-content:last-child {
  margin-bottom: 0;
}

/* 功能列表 */
.feature-list {
  /* 容器 */
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 60rpx;
  text-align: center;
}

.feature-info {
  flex: 1;
}

.feature-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999999;
}

/* 团队 */
.team-intro {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.team-list {
  /* 容器 */
}

.team-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.team-item:last-child {
  border-bottom: none;
}

.team-role {
  font-size: 26rpx;
  color: #999999;
  width: 160rpx;
}

.team-name {
  font-size: 28rpx;
  color: #333333;
}

/* 联系方式 */
.contact-item {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 26rpx;
  color: #999999;
  width: 160rpx;
  flex-shrink: 0;
}

.contact-value {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
  line-height: 1.6;
}

/* 版权 */
.copyright {
  text-align: center;
  padding: 30rpx 0 50rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.copyright text {
  font-size: 22rpx;
  color: #cccccc;
}
