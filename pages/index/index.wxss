.banner-swiper {
  width: 100%;
  height: 400rpx;
}

.banner-image-wrapper {
  width: 100%;
  height: 100%;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
}

.banner-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: flex-end;
  padding: 30rpx;
  box-sizing: border-box;
}

.banner-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  max-width: 80%;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.search-section {
  padding: 20rpx;
  background-color: #f8f8f8;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.clear-btn {
  font-size: 28rpx;
  color: #999999;
  padding: 8rpx;
  margin-left: 8rpx;
}

.search-options {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.option-item {
  padding: 10rpx 20rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666666;
  transition: all 0.3s ease;
}

.option-item.active {
  background-color: var(--theme-color);
  color: #ffffff;
}

.date-picker-section {
  margin-top: 16rpx;
}

.date-picker-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.date-picker-unit {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 180rpx;
}

.date-picker-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.date-picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.date-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.date-text {
  font-size: 26rpx;
  color: #333333;
}

.date-arrow {
  font-size: 20rpx;
  color: #999999;
}

.search-dropdown {
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-top: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.dropdown-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dropdown-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.dropdown-count {
  font-size: 24rpx;
  color: var(--theme-color);
}

.loading-state {
  padding: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999999;
}

.result-list {
  max-height: 500rpx;
}

.search-result-item {
  display: flex;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-result-item:last-child {
  border-bottom: none;
}

.result-image-wrapper {
  width: 120rpx;
  height: 90rpx;
  border-radius: 8rpx;
  overflow: hidden;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.result-image {
  width: 100%;
  height: 100%;
}

.result-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-content {
  flex: 1;
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.result-content-no-image {
  margin-left: 0;
}

.result-title {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 20rpx;
}

.title-normal {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.4;
}

.title-highlight {
  font-size: 28rpx;
  color: #E64340;
  font-weight: bold;
  line-height: 1.4;
}

.result-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-wrap: wrap;
}

.category-tag {
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.result-date {
  font-size: 22rpx;
  color: #999999;
}

.no-results {
  padding: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999999;
}

.pagination {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.page-btn {
  padding: 12rpx 24rpx;
  background-color: var(--theme-color);
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.page-btn.disabled {
  background-color: #cccccc;
  color: #ffffff;
}

.page-info {
  font-size: 26rpx;
  color: #666666;
}

.latest-news {
  padding: 0 20rpx 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.refresh-time {
  font-size: 22rpx;
  color: #bbbbbb;
}

.more-link {
  font-size: 26rpx;
  color: var(--theme-color);
}

.latest-loading {
  text-align: center;
  padding: 20rpx 0 30rpx;
  font-size: 26rpx;
  color: #999999;
}

.latest-no-more {
  text-align: center;
  padding: 20rpx 0 30rpx;
  font-size: 24rpx;
  color: #cccccc;
}

.news-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx 24rpx 24rpx 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.news-content {
  flex: 1;
  margin-right: 20rpx;
}

.news-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.news-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex-wrap: wrap;
}

.news-date {
  font-size: 24rpx;
  color: #999999;
}

.news-image-wrapper {
  width: 180rpx;
  height: 130rpx;
  border-radius: 8rpx;
  overflow: hidden;
  flex-shrink: 0;
  background-color: #f5f5f5;
  margin-right: 24rpx;
}

.news-image {
  width: 100%;
  height: 100%;
}

.news-content-no-image {
  margin-right: 0;
}

.year-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.year-picker-container {
  width: 100%;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.year-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.year-picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.year-picker-close {
  font-size: 36rpx;
  color: #999999;
  padding: 8rpx;
}

.year-picker-content {
  max-height: 600rpx;
  padding: 16rpx 0;
}

.year-picker-item {
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  color: #333333;
  text-align: center;
  transition: all 0.3s ease;
}

.year-picker-item.selected {
  background-color: var(--theme-color);
  color: #ffffff;
  font-weight: bold;
  border-radius: 32rpx;
}

.year-picker-item.hover {
  background-color: #e8f5e9;
  color: var(--theme-color);
  font-weight: bold;
  border-radius: 32rpx;
}
