.category-tabs {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
}

.tab-item {
  padding: 12rpx 30rpx;
  margin: 10rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #f5f5f5;
  border-radius: 30rpx;
}

.tab-item.active {
  color: #ffffff;
  background-color: #1AAD19;
}

.news-list {
  padding: 20rpx;
}

.news-item {
  display: flex;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.news-content {
  flex: 1;
  margin-right: 20rpx;
}

.news-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.news-summary {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.news-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.category-tag {
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.news-date {
  font-size: 24rpx;
  color: #999999;
}

.news-views {
  font-size: 24rpx;
  color: #999999;
}

.news-thumb-placeholder {
  width: 200rpx;
  height: 150rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f0f0;
}

.placeholder-text {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.refresh-bar {
  padding: 10rpx 30rpx;
  background-color: #f8f8f8;
  border-bottom: 1rpx solid #eeeeee;
}

.refresh-time {
  font-size: 22rpx;
  color: #bbbbbb;
}
