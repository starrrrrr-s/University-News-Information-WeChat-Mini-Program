<view class="container">
  <view class="lecture-detail" wx:if="{{lecture}}">
    <view class="lecture-image-wrapper">
      <view class="lecture-placeholder" style="background: linear-gradient(135deg, #1AAD19, #007AFF);">
        <text class="placeholder-text">{{lecture.category.charAt(0)}}</text>
      </view>
      <view class="lecture-badge {{lecture.isFree ? 'free' : 'paid'}}">{{lecture.isFree ? '免费' : '收费'}}</view>
    </view>

    <view class="lecture-content">
      <view class="lecture-title">{{lecture.title}}</view>

      <view class="info-card">
        <view class="info-row">
          <text class="label">主讲人：</text>
          <text class="value">{{lecture.speaker}}</text>
        </view>
        <view class="info-row">
          <text class="label">职称：</text>
          <text class="value">{{lecture.speakerTitle}}</text>
        </view>
        <view class="info-row">
          <text class="label">时间：</text>
          <text class="value">{{lecture.start_time || lecture.time}}</text>
        </view>
        <view class="info-row">
          <text class="label">地点：</text>
          <text class="value">{{lecture.location}}</text>
        </view>
        <view class="info-row">
          <text class="label">主办方：</text>
          <text class="value">{{lecture.organizer}}</text>
        </view>
        <view class="info-row">
          <text class="label">类型：</text>
          <text class="value">{{lecture.category}}</text>
        </view>
      </view>

      <view class="detail-section">
        <view class="section-title">讲座内容</view>
        <view class="detail-content" style="font-size: {{fontSize}}rpx;">{{lecture.content}}</view>
      </view>

      <!-- 讲座链接 -->
      <view class="detail-section" wx:if="{{lecture.link}}">
        <view class="section-title">查看原文</view>
        <view class="link-section">
          <view class="link-btn" bindtap="openLink">
            <text class="link-icon">🔗</text>
            <text class="link-text">点击打开链接</text>
          </view>
        </view>
      </view>

      <!-- 评论区 -->
      <view class="comment-section">
        <view class="comment-header">
          <text class="comment-title">听讲心得 ({{commentTotal}})</text>
        </view>

        <!-- 评论列表 -->
        <view class="comment-list" wx:if="{{commentList.length > 0}}">
          <view class="comment-item" wx:for="{{commentList}}" wx:key="id">
            <!-- 置顶标识 -->
            <view class="top-badge" wx:if="{{item.is_top}}">置顶</view>

            <view class="comment-main">
              <!-- 用户头像 -->
              <view class="comment-avatar">
                <image wx:if="{{item.user && item.user.avatar_url}}" src="{{item.user.avatar_url}}" mode="aspectFill" class="avatar-img" />
                <view wx:else class="avatar-placeholder-small">
                  <text>{{item.user ? item.user.nickname.charAt(0) : '?'}}</text>
                </view>
              </view>

              <view class="comment-body">
                <view class="comment-user-name">{{item.user ? item.user.nickname : '匿名用户'}}</view>
                <view class="reply-to" wx:if="{{item.parent_id}}">
                  <text class="reply-label">回复</text>
                </view>
                <view class="comment-content">{{item.content}}</view>
                <view class="comment-footer">
                  <text class="comment-time">{{item.createdAt}}</text>
                  <text class="reply-btn" bindtap="onReply" data-id="{{item.id}}" data-nickname="{{item.user ? item.user.nickname : '匿名用户'}}">回复</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 空评论提示 -->
        <view class="comment-empty" wx:if="{{commentList.length === 0 && !commentLoading}}">
          <text>暂无心得，快来分享你的听讲感受吧～</text>
        </view>

        <!-- 加载更多 -->
        <view class="load-more" wx:if="{{hasMoreComments}}" bindtap="loadMoreComments">
          <text>加载更多</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:if="{{!lecture}}">
    <text>讲座不存在或已被删除</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar" wx:if="{{lecture}}">
    <button class="action-btn comment-btn" bindtap="onFocusComment">
      <text class="action-icon">💬</text>
      <text class="action-text">写心得</text>
    </button>
    <button class="action-btn share-btn" open-type="share">
      <text class="action-icon">↗</text>
      <text class="action-text">分享</text>
    </button>
  </view>

  <!-- 评论输入框遮罩 -->
  <view class="comment-input-mask" wx:if="{{showCommentInput}}" bindtap="onHideCommentInput"></view>
  <!-- 评论输入框 -->
  <view class="comment-input-bar" wx:if="{{showCommentInput}}">
    <view class="reply-hint" wx:if="{{replyTo}}">
      <text>回复 @{{replyTo.nickname}}</text>
      <text class="cancel-reply" bindtap="onCancelReply">取消回复</text>
    </view>
    <view class="input-row">
      <input
        class="comment-input"
        value="{{commentContent}}"
        bindinput="onCommentInput"
        placeholder="{{replyTo ? '回复 @' + replyTo.nickname : '分享你的听讲心得...'}}"
        maxlength="500"
        focus="{{commentInputFocus}}"
        adjust-position="{{true}}"
      />
      <button class="send-btn" bindtap="onSubmitComment" disabled="{{commentContent.length === 0}}">发送</button>
    </view>
  </view>
</view>
