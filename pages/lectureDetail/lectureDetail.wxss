.lecture-detail {
  min-height: 100vh;
  background-color: #f8f8f8;
}

.lecture-image-wrapper {
  position: relative;
  height: 400rpx;
}

.lecture-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1AAD19, #007AFF);
}

.placeholder-text {
  color: #ffffff;
  font-size: 120rpx;
  font-weight: bold;
}

.lecture-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  border-radius: 30rpx;
}

.lecture-badge.free {
  background-color: #1AAD19;
}

.lecture-badge.paid {
  background-color: #E64340;
}

.lecture-content {
  padding: 30rpx;
}

.lecture-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 30rpx;
}

.info-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.info-row {
  display: flex;
  padding: 16rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  color: #999999;
  width: 150rpx;
}

.info-row .value {
  color: #333333;
  flex: 1;
}

.detail-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #eeeeee;
}

.detail-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}