.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f5f5f5;
}

.admin-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.add-btn {
  background-color: #1AAD19;
  color: #ffffff;
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  border: none;
}

.news-list {
  padding: 20rpx;
}

.news-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.news-info {
  margin-bottom: 20rpx;
}

.news-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.news-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-tag {
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.news-date {
  font-size: 24rpx;
  color: #999999;
}

.news-actions {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}

.action-btn {
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  border-radius: 6rpx;
  border: none;
}

.action-btn.edit {
  background-color: #1AAD19;
  color: #ffffff;
}

.action-btn.delete {
  background-color: #E64340;
  color: #ffffff;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}