<view class="container">
  <view class="form-section">
    <view class="form-item">
      <text class="form-label required">标题</text>
      <input class="form-input" placeholder="请输入新闻标题" value="{{title}}" bindinput="onTitleInput" maxlength="100" />
    </view>

    <view class="form-item">
      <text class="form-label required">分类</text>
      <picker mode="selector" range="{{categoryList}}" range-key="name" value="{{selectedCategoryIndex}}" bindchange="onCategoryChange">
        <view class="form-picker">
          <text class="{{categoryList[selectedCategoryIndex] ? '' : 'placeholder'}}">
            {{categoryList[selectedCategoryIndex] ? categoryList[selectedCategoryIndex].name : '请选择分类'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label required">作者</text>
      <input class="form-input" placeholder="请输入作者/来源" value="{{author}}" bindinput="onAuthorInput" maxlength="50" />
    </view>

    <view class="form-item">
      <text class="form-label required">日期</text>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="form-picker">
          <text class="{{date ? '' : 'placeholder'}}">{{date || '请选择日期'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">定时发布</text>
      <switch class="form-switch" checked="{{isTimedPublish}}" bindchange="onTimedPublishChange" />
    </view>

    <block wx:if="{{isTimedPublish}}">
      <view class="form-item">
        <text class="form-label required">发布日期</text>
        <picker mode="date" value="{{publishDate}}" bindchange="onPublishDateChange">
          <view class="form-picker">
            <text class="{{publishDate ? '' : 'placeholder'}}">{{publishDate || '请选择发布日期'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label required">发布时间</text>
        <picker mode="time" value="{{publishTime}}" bindchange="onPublishTimeChange">
          <view class="form-picker">
            <text class="{{publishTime ? '' : 'placeholder'}}">{{publishTime || '请选择发布时间'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </block>

    <view class="form-item">
      <text class="form-label required">摘要</text>
      <textarea class="form-textarea" placeholder="请输入新闻摘要（100字以内）" value="{{summary}}" bindinput="onSummaryInput" maxlength="200" />
    </view>

    <view class="form-item">
      <text class="form-label required">正文内容</text>
      <textarea class="form-textarea content" placeholder="请输入新闻正文内容" value="{{content}}" bindinput="onContentInput" />
    </view>
  </view>

  <view class="form-actions">
    <button class="save-btn" bindtap="onSave">{{isEdit ? '保存修改' : '发布新闻'}}</button>
  </view>
</view>
