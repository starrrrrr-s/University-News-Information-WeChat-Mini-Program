.theme-config {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.color-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: calc(25% - 22rpx);
}

.color-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  margin-bottom: 12rpx;
  transition: all 0.3s ease;
}

.color-item.selected .color-circle {
  border-color: #333;
  transform: scale(1.1);
}

.color-name {
  font-size: 24rpx;
  color: #666;
}

.preview-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.preview-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.preview-card {
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
}

.preview-nav {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.preview-tabbar {
  display: flex;
  background-color: #fff;
  border-top: 1rpx solid #eee;
}

.preview-tab {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.action-section {
  display: flex;
  gap: 20rpx;
}

.reset-btn {
  flex: 1;
  background-color: #ffffff;
  color: #666;
  font-size: 28rpx;
  padding: 24rpx 0;
  border-radius: 44rpx;
  border: 1rpx solid #ddd;
}

.apply-btn {
  flex: 2;
  background-color: var(--theme-color);
  color: #ffffff;
  font-size: 28rpx;
  padding: 24rpx 0;
  border-radius: 44rpx;
}