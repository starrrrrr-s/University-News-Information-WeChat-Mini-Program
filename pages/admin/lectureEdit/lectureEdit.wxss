.form-section {
  padding: 20rpx;
}

.form-item {
  background-color: #ffffff;
  padding: 30rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  font-size: 30rpx;
  color: #333333;
  padding: 10rpx 0;
  box-sizing: border-box;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  color: #333333;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-arrow {
  color: #cccccc;
  font-size: 36rpx;
}

.form-textarea {
  width: 100%;
  font-size: 28rpx;
  color: #333333;
  padding: 10rpx 0;
  min-height: 200rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.form-actions {
  padding: 20rpx 20rpx 40rpx;
}

.save-btn {
  background-color: #1AAD19;
  color: #ffffff;
  font-size: 32rpx;
  padding: 26rpx;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(26, 173, 25, 0.3);
}
