.admin-header {
  padding: 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f5f5f5;
}

.admin-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* ─── 筛选栏 ─────────────────────────────────────────────── */

.filter-bar {
  display: flex;
  background-color: #ffffff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #666666;
  border-bottom: 4rpx solid transparent;
}

.filter-item.active {
  color: #1AAD19;
  border-bottom-color: #1AAD19;
  font-weight: bold;
}

.status-bar {
  display: flex;
  background-color: #fafafa;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 24rpx;
  color: #999999;
}

.status-item.active {
  color: #007AFF;
  font-weight: bold;
}

/* ─── 评论卡片 ───────────────────────────────────────────── */

.comment-list {
  padding: 20rpx;
}

.comment-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background-color: #1AAD19;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
}

.avatar-small text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

.user-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
}

.meta-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.target-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.news-tag {
  background-color: #e8f5e9;
  color: #1AAD19;
}

.lecture-tag {
  background-color: #e3f2fd;
  color: #007AFF;
}

.status-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.status-0 {
  background-color: #fff8e1;
  color: #FF9500;
}

.status-1 {
  background-color: #e8f5e9;
  color: #1AAD19;
}

.status-2 {
  background-color: #fce4ec;
  color: #E64340;
}

.top-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background-color: #E64340;
  color: #ffffff;
}

.card-content {
  font-size: 28rpx;
  color: #444444;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.card-time {
  font-size: 22rpx;
  color: #bbbbbb;
  margin-bottom: 20rpx;
}

/* ─── 操作按钮 ───────────────────────────────────────────── */

.card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 6rpx;
  border: none;
  line-height: 1.5;
}

.approve-btn {
  background-color: #1AAD19;
  color: #ffffff;
}

.reject-btn {
  background-color: #FF9500;
  color: #ffffff;
}

.top-btn {
  background-color: #007AFF;
  color: #ffffff;
}

.untop-btn {
  background-color: #f0f0f0;
  color: #666666;
}

.delete-btn {
  background-color: #E64340;
  color: #ffffff;
}

/* ─── 其他 ───────────────────────────────────────────────── */

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
  color: #1AAD19;
  font-size: 26rpx;
}

.loading-tip {
  text-align: center;
  padding: 30rpx 0;
  color: #999999;
  font-size: 26rpx;
}
