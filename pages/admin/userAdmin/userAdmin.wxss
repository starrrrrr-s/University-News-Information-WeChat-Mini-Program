.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f5f5f5;
}

.admin-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.user-list {
  padding: 20rpx;
}

.user-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-role {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background-color: #f5f5f5;
  color: #666666;
}

.user-role.admin {
  background-color: #E64340;
  color: #ffffff;
}

.user-date {
  font-size: 24rpx;
  color: #999999;
}

.user-actions {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 6rpx;
  border: none;
}

.action-btn.setAdmin {
  background-color: #1AAD19;
  color: #ffffff;
}

.action-btn.remove {
  background-color: #FF9500;
  color: #ffffff;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}